# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — conversation and move generation (without it Koda runs in labeled offline sample mode)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role (required for autonomous briefs cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — email digests (optional, logs to console without)
RESEND_API_KEY=re_...

# Cron secret — protects the /api/cron/brief endpoint
CRON_SECRET=your-cron-secret
# Force the deterministic offline provider (used by tests)
# KODA_AI_MOCK=1

# Voice: natural text-to-speech for Talk to Koda calls (OpenAI TTS).
# Without it, calls fall back to the browser's built-in voices.
OPENAI_API_KEY=sk-...
# Optional overrides: KODA_TTS_MODEL (default gpt-4o-mini-tts), KODA_TTS_VOICE (default coral)
