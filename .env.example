# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — conversation and move generation (without it Koda runs in labeled offline sample mode)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role (required for autonomous briefs cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — email digests (optional, logs to console without)
RESEND_API_KEY=re_...

# Cron secret — protects the /api/cron/brief and /api/cron/sync endpoints
CRON_SECRET=your-cron-secret
# Force the deterministic offline provider (used by tests)
# KODA_AI_MOCK=1

# Google OAuth — Calendar and Gmail integrations (optional; without it they
# run in labeled mock mode). Gmail additionally requires the gmail.readonly
# and gmail.compose scopes on the consent screen.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Token encryption key — 32 bytes base64 (generate: openssl rand -base64 32).
# Rotating it invalidates stored integration tokens; users reconnect.
KODA_TOKEN_ENC_KEY=your-32-byte-base64-key

# Force deterministic mock integration adapters (used by tests)
# KODA_INTEGRATIONS_MOCK=1
