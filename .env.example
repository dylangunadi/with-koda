# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — move generation (required for AI moves, falls back to mock without)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase service role (required for autonomous briefs cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — email digests (optional, logs to console without)
RESEND_API_KEY=re_...

# Cron secret — protects the /api/cron/brief endpoint
CRON_SECRET=your-cron-secret
